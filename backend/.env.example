# --- ElevenLabs ---
ELEVENLABS_API_KEY=your_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# --- Serial / Arduino ---
SERIAL_PORT=COM3                 # Windows. macOS e.g. /dev/cu.usbmodem14101

# --- OpenSky ---
# Auth is now OAuth2 client-credentials only (username/password no longer work).
# Create an API client at https://opensky-network.org → Account → API clients.
# Leave blank to use anonymous access (10s resolution, 400 credits/day).
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Query bounding box (degrees). Defaults to the YYZ / Great Lakes region so the
# tracked aircraft shows up inside the dashboard map view.
OPENSKY_LAMIN=41.0
OPENSKY_LOMIN=-84.0
OPENSKY_LAMAX=47.0
OPENSKY_LOMAX=-74.0

# --- Detection / timing ---
TURBULENCE_THRESHOLD=5.0         # m/s vertical-rate spike (real OpenSky signal)
CONFIRMATION_TIMEOUT=5           # seconds to wait for voice confirmation
POLL_INTERVAL=10                 # seconds between OpenSky polls (feed is ~10s)

# --- Demo fallbacks ---
USE_REPLAY=false                 # true → ignore OpenSky, play recorded_flight.json
SKIP_VOICE=false                 # true → skip mic, auto-confirm (noisy-room safe)
